   "source": [
    "# 模拟读取每个模型的单独数据集\n",
    "# 影像组学+生境分析 良恶性\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import roc_curve, auc\n",
    "\n",
    "# data_model1 = pd.read_csv(r\"<PROJECT_ROOT>\\model\\ori_results.csv\")  # 包含 true_labels 和 probs\n",
    "data_model1 = pd.read_csv(r\"<PROJECT_ROOT>\\test_result\\in_0427.csv\")\n",
    "data_model2 = pd.read_csv(r\"<PROJECT_ROOT>\\test_result\\in_sub_0427.csv\")\n",
    "data_model3 = pd.read_csv(r\"<PROJECT_ROOT>\\test_result\\out_0428.csv\")\n",
    "data_model4 = pd.read_csv(r\"<PROJECT_ROOT>\\test_result\\out_sub_0427.csv\")\n",
    "data_model5 = pd.read_csv(r\"<PROJECT_ROOT>\\test_result\\in_out_sub_2_0428.csv\")\n",
    "\n",
    "auc1 = 0.886\n",
    "models_data = {\n",
    "    'wash-in': data_model1, \n",
    "    'wash-in-habitat': data_model2,\n",
    "    'wash-out': data_model3,\n",
    "    'wash-out-habitat': data_model4,\n",
    "    'combined': data_model5,\n",
    "}\n",
    "\n",
    "plt.figure(figsize=(10, 8))\n",
    "\n",
